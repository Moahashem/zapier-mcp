# ============================================================
# Zapier MCP Proxy — Environment Variables
# ============================================================
# Copy this to .env and fill in your per-agent values.
# Each agent (Claude Desktop, Cowork, Claude Code, ClawBot) should
# have its own Zapier MCP server URL so usage is attributed per-agent.
# ============================================================

# REQUIRED — your Zapier MCP server URL.
#
# Get this at https://mcp.zapier.com:
#   1. Create (or open) a server
#   2. Configure tab → add the actions you want this agent to have
#   3. Connect tab → copy the server URL
#
# The URL contains an embedded token. Treat it like a password.
# Example shape: https://mcp.zapier.com/api/mcp/s/<long-token>/mcp
ZAPIER_MCP_URL=""

# OPTIONAL — substring filter applied to tool names + descriptions.
# Comma-separated, case-insensitive. Default: no filter (expose everything).
# Useful if you want this agent to only see, say, Gmail + Slack actions:
#   ZAPIER_MATCH_TERMS="gmail,slack"
ZAPIER_MATCH_TERMS=""

# OPTIONAL — prefix added to every exposed tool name. Default: "" (no rename).
# Set to e.g. "zapier_" if you want every tool clearly tagged in the agent's UI.
ZAPIER_TOOL_PREFIX=""

# OPTIONAL — keep Zapier meta tools like get_configuration_url. Default: true
# (the proxy is intentionally generic, so meta tools are useful here).
ZAPIER_KEEP_META_TOOLS="true"

# OPTIONAL — log level. silent | error | warn | info | debug.
ZAPIER_LOG_LEVEL="info"

# OPTIONAL — per-request timeout in milliseconds. Default 60000.
ZAPIER_TIMEOUT_MS="60000"
