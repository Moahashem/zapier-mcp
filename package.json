{
  "name": "zapier-mcp-proxy",
  "version": "0.1.0",
  "description": "Model Context Protocol server that proxies Zapier MCP over stdio with per-agent identity and optional tool filtering. Companion to leadsimple-mcp — same architecture, no app-specific filter.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zapier-mcp-proxy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "probe": "tsx src/probe.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "zapier",
    "proxy",
    "claude",
    "cowork",
    "ffl",
    "flatfeelandlord"
  ],
  "author": "Mo Hashem <mo@flatfeelandlord.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Moahashem/zapier-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Moahashem/zapier-mcp/issues"
  },
  "homepage": "https://github.com/Moahashem/zapier-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
